{
  "info": {
    "_postman_id": "bfd5d710-1e5b-4395-8889-408935c1234b",
    "name": "Mini ERP API",
    "description": "Comprehensive API documentation and Postman collection for the Mini ERP system (Backend). Serves core workflows for Auth, Staff Management, Inventory Products CRUD, Sales Logs, Dashboard KPI stats, and Notifications.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication & Users",
      "item": [
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@gmail.com\",\n  \"password\": \"12345678\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "Exchanges email and password credentials for an access token and refresh token. Supported roles: SUPER_ADMIN, ADMIN, MANAGER, EMPLOYEE."
          },
          "response": []
        },
        {
          "name": "Register User (Public)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Public Employee\",\n  \"email\": \"emp_public@gmail.com\",\n  \"password\": \"password123\",\n  \"contact\": \"+8801700000001\",\n  \"location\": \"Dhaka\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/user",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "user"
              ]
            },
            "description": "Public sign up route. Defaults role to EMPLOYEE and triggers account verification email with OTP."
          },
          "response": []
        },
        {
          "name": "Create Staff (Admin Only)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Manager\",\n  \"email\": \"jane_manager@gmail.com\",\n  \"password\": \"password123\",\n  \"role\": \"MANAGER\",\n  \"contact\": \"+8801700000002\",\n  \"location\": \"Chittagong\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/user/create-staff",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "user",
                "create-staff"
              ]
            },
            "description": "Allows SUPER_ADMIN and ADMIN roles to create pre-verified staff accounts (ADMIN, MANAGER, or EMPLOYEE) that are active and ready for immediate login."
          },
          "response": []
        },
